        switch (choice) {

           
         case 1:
            cout << "enter character: ";
            cin >> ch;

            undostack.push(text);   
            text += ch;

            redostack.clear();      
            break;

            
         case 2:
            if (text.empty()) {
                cout << "nothing to delete!" << endl;
                break;
            }

            undostack.push(text);
            text.pop_back();

            redostack.clear();
            break;

            
         case 3:
            if (undostack.isempty()) {
                cout << "nothing to undo!" << endl;
                break;
            }

            redostack.push(text);
